@page "/consumo"
@using PROJETO.MEU.Models
@using PROJETO.MEU.Services
@inject IRegistroConsumoService ConsumoService
@inject IEstudanteService EstudanteService
@inject IRefeicaoService RefeicaoService
@rendermode InteractiveServer

<div class="container mt-5">
    <h1>Registrar Consumo de Refeição</h1>

    @if (!string.IsNullOrEmpty(mensagem))
    {
        <div class="alert alert-info">@mensagem</div>
    }

    @if (!string.IsNullOrEmpty(erro))
    {
        <div class="alert alert-danger">@erro</div>
    }

    <div class="card mb-4">
        <div class="card-header">
            <h5>Registrar Nova Refeição</h5>
        </div>
        <div class="card-body">
            <form @onsubmit="RegistrarConsumo">
                <div class="mb-3">
                    <label for="estudante" class="form-label">Estudante</label>
                    <select class="form-control" id="estudante" @bind="estudanteId" required>
                        <option value="">-- Selecione Estudante --</option>
                        @foreach (var est in estudantes)
                        {
                            <option value="@est.Id">@est.Nome (@est.Matricula)</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label for="refeicao" class="form-label">Refeição</label>
                    <select class="form-control" id="refeicao" @bind="refeicaoId" required>
                        <option value="">-- Selecione Refeição --</option>
                        @foreach (var refeicao in refeicoes)
                        {
                            <option value="@refeicao.Id">@refeicao.Nome (@refeicao.Tipo)</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label for="turno" class="form-label">Turno</label>
                    <select class="form-control" id="turno" @bind="turno" required>
                        <option value="">-- Selecione Turno --</option>
                        <option value="Café da manhã">Café da manhã</option>
                        <option value="Almoço">Almoço</option>
                        <option value="Café da tarde">Café da tarde</option>
                        <option value="Janta">Janta</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary">Registrar Consumo</button>
            </form>
        </div>
    </div>

    <h3>Últimos Registros</h3>
    @if (registros.Count == 0)
    {
        <p>Nenhum registro de consumo.</p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Estudante</th>
                    <th>Refeição</th>
                    <th>Turno</th>
                    <th>Data/Hora</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var registro in registros)
                {
                    <tr>
                        <td>@registro.Estudante?.Nome</td>
                        <td>@registro.Refeicao?.Nome</td>
                        <td>@registro.Turno</td>
                        <td>@registro.DataConsumo.ToString("dd/MM/yyyy HH:mm:ss")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<Estudante> estudantes = new();
    private List<Refeicao> refeicoes = new();
    private List<RegistroConsumo> registros = new();
    private string estudanteId = "";
    private string refeicaoId = "";
    private string turno = "";
    private string mensagem = "";
    private string erro = "";

    protected override async Task OnInitializedAsync()
    {
        await CarregarEstudantes();
        await CarregarRefeicoes();
        await CarregarRegistros();
    }

    private async Task CarregarEstudantes()
    {
        try
        {
            estudantes = (await EstudanteService.GetAllAsync()).ToList();
        }
        catch (Exception ex)
        {
            erro = $"Erro ao carregar estudantes: {ex.Message}";
        }
    }

    private async Task CarregarRefeicoes()
    {
        try
        {
            refeicoes = (await RefeicaoService.GetAllAsync()).ToList();
        }
        catch (Exception ex)
        {
            erro = $"Erro ao carregar refeições: {ex.Message}";
        }
    }

    private async Task CarregarRegistros()
    {
        try
        {
            registros = (await ConsumoService.GetAllAsync()).ToList();
        }
        catch (Exception ex)
        {
            erro = $"Erro ao carregar registros: {ex.Message}";
        }
    }

    private async Task RegistrarConsumo()
    {
        try
        {
            if (!int.TryParse(estudanteId, out var estId) || !int.TryParse(refeicaoId, out var refId))
            {
                erro = "Selecione estudante e refeição válidos.";
                return;
            }

            await ConsumoService.RegisterConsumoAsync(estId, refId, turno);
            mensagem = "Consumo registrado com sucesso!";
            estudanteId = "";
            refeicaoId = "";
            turno = "";
            await CarregarRegistros();
            erro = "";
        }
        catch (Exception ex)
        {
            erro = $"Erro ao registrar consumo: {ex.Message}";
        }
    }
}
