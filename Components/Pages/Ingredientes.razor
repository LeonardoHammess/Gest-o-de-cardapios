@page "/ingredientes"
@using PROJETO.MEU.Models
@using PROJETO.MEU.Services
@inject IIngredienteService IngredienteService
@rendermode InteractiveServer

<div class="container mt-5">
    <h1>Gerenciar Ingredientes</h1>

    @if (!string.IsNullOrEmpty(mensagem))
    {
        <div class="alert alert-info">@mensagem</div>
    }

    @if (!string.IsNullOrEmpty(erro))
    {
        <div class="alert alert-danger">@erro</div>
    }

    <div class="card mb-4">
        <div class="card-header">
            <h5>@(editandoId == null ? "Novo Ingrediente" : "Editar Ingrediente")</h5>
        </div>
        <div class="card-body">
            <form @onsubmit="SalvarIngrediente">
                <div class="mb-3">
                    <label for="nome" class="form-label">Nome</label>
                    <input type="text" class="form-control" id="nome" @bind="novoIngrediente.Nome" required />
                </div>

                <div class="mb-3">
                    <label for="descricao" class="form-label">Descrição</label>
                    <textarea class="form-control" id="descricao" @bind="novoIngrediente.Descricao" rows="3"></textarea>
                </div>

                <button type="submit" class="btn btn-primary">Salvar</button>
                @if (editandoId != null)
                {
                    <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                }
            </form>
        </div>
    </div>

    <h3>Ingredientes Cadastrados</h3>
    @if (ingredientes.Count == 0)
    {
        <p>Nenhum ingrediente cadastrado.</p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Descrição</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ingrediente in ingredientes)
                {
                    <tr>
                        <td>@ingrediente.Nome</td>
                        <td>@ingrediente.Descricao</td>
                        <td>
                            <button class="btn btn-sm btn-warning" @onclick="() => Editar(ingrediente)">Editar</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => Deletar(ingrediente.Id)">Deletar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<Ingrediente> ingredientes = new();
    private Ingrediente novoIngrediente = new();
    private int? editandoId = null;
    private string mensagem = "";
    private string erro = "";

    protected override async Task OnInitializedAsync()
    {
        await CarregarIngredientes();
    }

    private async Task CarregarIngredientes()
    {
        try
        {
            ingredientes = (await IngredienteService.GetAllAsync()).ToList();
        }
        catch (Exception ex)
        {
            erro = $"Erro ao carregar ingredientes: {ex.Message}";
        }
    }

    private async Task SalvarIngrediente()
    {
        try
        {
            if (editandoId == null)
            {
                await IngredienteService.CreateAsync(novoIngrediente.Nome, novoIngrediente.Descricao);
                mensagem = "Ingrediente criado com sucesso!";
            }
            else
            {
                await IngredienteService.UpdateAsync(editandoId.Value, novoIngrediente.Nome, novoIngrediente.Descricao);
                mensagem = "Ingrediente atualizado com sucesso!";
                editandoId = null;
            }

            novoIngrediente = new();
            await CarregarIngredientes();
            erro = "";
        }
        catch (Exception ex)
        {
            erro = $"Erro ao salvar ingrediente: {ex.Message}";
        }
    }

    private void Editar(Ingrediente ingrediente)
    {
        novoIngrediente = new Ingrediente
        {
            Nome = ingrediente.Nome,
            Descricao = ingrediente.Descricao
        };
        editandoId = ingrediente.Id;
    }

    private void Cancelar()
    {
        novoIngrediente = new();
        editandoId = null;
    }

    private async Task Deletar(int id)
    {
        try
        {
            await IngredienteService.DeleteAsync(id);
            mensagem = "Ingrediente deletado com sucesso!";
            await CarregarIngredientes();
            erro = "";
        }
        catch (Exception ex)
        {
            erro = $"Erro ao deletar ingrediente: {ex.Message}";
        }
    }
}
